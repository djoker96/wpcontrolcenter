{
  "name": "wp-control-center-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "cd apps/web && bun run dev",
    "dev:api": "cd apps/api && bun run dev",
    "dev:worker": "cd apps/worker && bun run dev",
    "build:all": "npm run build -w packages/shared && npm run build -w packages/database && npm run build -w apps/api && npm run build -w apps/web && npm run build -w apps/worker",
    "db:generate": "npm run generate -w packages/database",
    "db:migrate": "npm run migrate:dev -w packages/database",
    "db:seed": "npm run seed -w packages/database",
    "test:agent": "node --test \"wordpress-agent/test/**/*.test.js\""
  },
  "overrides": {
    "lodash": "^4.18.1"
  }
}
