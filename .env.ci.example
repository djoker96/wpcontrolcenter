# CI / Production Environment Variables
# Copy this file to .env.ci (CI) or .env.production (deployment) and fill in real values.
# NEVER commit files containing real secrets to version control.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD
POSTGRES_DB=wp_control_center
DATABASE_URL=postgresql://postgres:CHANGE_ME_USE_A_STRONG_PASSWORD@postgres:5432/wp_control_center?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Auth
JWT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET
JWT_EXPIRES_IN=1d

# Encryption (32-byte hex key for AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_32_BYTE_HEX_KEY

# App ports (optional, defaults shown)
# API_PORT=3003
# WEB_PORT=5001
# NGINX_PORT=80
# NEXT_PUBLIC_API_URL=http://localhost/api

# Agent
UPTIME_CHECK_INTERVAL_SECONDS=300
