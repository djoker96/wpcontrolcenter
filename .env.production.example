# === Database ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password-32chars
POSTGRES_DB=wp_control_center

# === JWT ===
JWT_SECRET=change-this-to-a-random-64-char-secret
JWT_EXPIRES_IN=1d

# === Agent Encryption (generate with: openssl rand -hex 32) ===
AGENT_ENCRYPTION_KEY=change-this-to-64-hex-characters

# === Seed Admin (required for production seed) ===
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-this-admin-password
RUN_SEED=false

# === Frontend ===
NEXT_PUBLIC_API_URL=https://your-domain.com/api
CORS_ORIGIN=https://your-domain.com

# === Cloudflare Tunnel ===
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token
